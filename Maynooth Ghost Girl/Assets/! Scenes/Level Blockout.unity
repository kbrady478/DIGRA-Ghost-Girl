      propertyPath: 'normal_Reinteract_Dialogue.Array.data[0]'
      value: Have you asked your friend for cheese yet?
      objectReference: {fileID: 0}
    - target: {fileID: 3450196841581608418, guid: 29870e55c034c1549bc88aaa7a0c602b, type: 3}
      propertyPath: 'pleased_Reinteract_Dialogue.Array.data[0]'
      value: Thanks for that cheese. That was stinky stuff.
      objectReference: {fileID: 0}
