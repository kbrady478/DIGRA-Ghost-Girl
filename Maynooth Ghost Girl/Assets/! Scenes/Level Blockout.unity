      objectReference: {fileID: 0}
    - target: {fileID: 3450196841581608418, guid: 29870e55c034c1549bc88aaa7a0c602b, type: 3}
      propertyPath: 'first_Dialogue.Array.data[1]'
      value: You want to help me? Uhh... let's see...
